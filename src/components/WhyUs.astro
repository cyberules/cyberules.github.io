---
const stats = [
  { value: '10+',  label: 'Years in cloud engineering'      },
  { value: '500+', label: 'Workloads running with HA & automated failover' },
  { value: '3',    label: 'Major cloud platforms'           },
  { value: '100%', label: 'Security-first mindset'          },
];

const pillars = [
  {
    icon: `<svg width="22" height="22" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
    title: 'Speed without compromise',
    body: 'We deliver fast — without cutting corners on security, reliability, or operational maturity.',
  },
  {
    icon: `<svg width="22" height="22" fill="none" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Security by design',
    body: 'Every architecture we build has defence-in-depth, least-privilege access, and automated compliance baked in from day one.',
  },
  {
    icon: `<svg width="22" height="22" fill="none" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Embedded partnership',
    body: 'We work as an extension of your engineering team — transferring knowledge, not creating dependency.',
  },
  {
    icon: `<svg width="22" height="22" fill="none" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Built for scale',
    body: 'From zero to global scale — our patterns are designed to grow with you, not become a bottleneck.',
  },
];
---
<section id="why-us" class="py-28 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-blue-950/20 via-transparent to-cyan-950/10 pointer-events-none"></div>
  <div class="max-w-7xl mx-auto px-6">

    <!-- Stats bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-white/5 rounded-2xl overflow-hidden mb-20">
      {stats.map(s => (
        <div class="bg-[#060d1f] px-8 py-10 text-center">
          <div class="text-4xl font-extrabold text-white mb-2">{s.value}</div>
          <div class="text-slate-400 text-sm">{s.label}</div>
        </div>
      ))}
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <div>
        <span class="text-cyan-400 text-sm font-semibold uppercase tracking-widest">Why Cyberules Consultancy</span>
        <h2 class="mt-3 text-4xl md:text-5xl font-extrabold text-white leading-tight">
          Battle-tested expertise.<br />
          <span class="text-slate-400">Zero guesswork.</span>
        </h2>
        <p class="mt-5 text-slate-400 text-lg leading-relaxed">
          We've been in the trenches of cloud-native transformation since before it was a buzzword.
          Whether you're migrating a monolith, hardening a Kubernetes fleet, or building a zero-trust network —
          we bring the patterns and scars to get it right.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {pillars.map(p => (
          <div class="p-5 rounded-xl bg-white/[0.03] border border-white/[0.07] hover:border-cyan-500/20 transition-colors">
            <div class="text-cyan-400 mb-3">
              <Fragment set:html={p.icon} />
            </div>
            <h3 class="text-white font-semibold text-sm mb-1.5">{p.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
