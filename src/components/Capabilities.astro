---
const capabilities = [
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Cloud Migration & Modernisation',
    description: 'End-to-end migration and modernisation of legacy workloads to cloud-native architectures on AWS, Azure, and GCP — using IaC, containerisation, and event-driven patterns.',
    tags: ['AWS', 'Azure', 'GCP', 'Terraform', 'Containers'],
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><polyline points="3.27 6.96 12 12.01 20.73 6.96" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="22.08" x2="12" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
    title: 'Kubernetes at Scale',
    description: 'Design, deploy, and operate production-grade Kubernetes clusters across multi-region, multi-cloud topologies. Fleet management, autoscaling, GitOps, and service mesh.',
    tags: ['Kubernetes', 'Helm', 'ArgoCD', 'Istio', 'Karpenter'],
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'DevSecOps',
    description: 'Shift security left — integrating vulnerability scanning, SAST/DAST, secrets management, automated patching, and policy enforcement directly into your CI/CD pipelines.',
    tags: ['Trivy', 'Vault', 'OPA', 'Snyk', 'SBOM'],
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Monitoring & Reliability',
    description: 'Full-stack observability with metrics, tracing, and logs. SLO/SLI frameworks, alerting runbooks, chaos engineering, and incident management for high-availability systems.',
    tags: ['Prometheus', 'Grafana', 'OpenTelemetry', 'PagerDuty'],
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
    title: 'Scalable Architectures',
    description: 'Design patterns for hyper-growth: event-driven microservices, CQRS, distributed caching, multi-region active-active, and cost-optimised auto-scaling strategies.',
    tags: ['Microservices', 'Kafka', 'Redis', 'CDN', 'FinOps'],
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><polyline points="14 2 14 8 20 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
    title: 'Infrastructure as Code',
    description: 'GitOps-first infrastructure provisioning with Terraform, Pulumi, and Crossplane. Modular, reusable, and policy-compliant IaC at enterprise scale.',
    tags: ['Terraform', 'Pulumi', 'Crossplane', 'Atlantis', 'CDK'],
  },
];
---
<section id="capabilities" class="py-28 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-950/10 to-transparent pointer-events-none"></div>
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-cyan-400 text-sm font-semibold uppercase tracking-widest">What we do</span>
      <h2 class="mt-3 text-4xl md:text-5xl font-extrabold text-white">Our Capabilities</h2>
      <p class="mt-4 text-slate-400 text-lg max-w-2xl mx-auto">
        Deep expertise across the full cloud-native lifecycle — from architecture to operations.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {capabilities.map(cap => (
        <div class="group relative p-7 rounded-2xl bg-white/[0.03] border border-white/[0.07] hover:border-cyan-500/30 hover:bg-cyan-500/[0.04] transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400 mb-5 group-hover:bg-cyan-500/20 transition-colors">
            <Fragment set:html={cap.icon} />
          </div>
          <h3 class="text-white font-bold text-lg mb-2">{cap.title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-5">{cap.description}</p>
          <div class="flex flex-wrap gap-2">
            {cap.tags.map(tag => (
              <span class="px-2.5 py-1 rounded-md bg-slate-800/60 border border-white/5 text-xs text-slate-400 font-medium">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
