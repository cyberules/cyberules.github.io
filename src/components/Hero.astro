---
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <!-- Grid background -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(6,182,212,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(6,182,212,0.03)_1px,transparent_1px)] bg-[size:72px_72px]"></div>

  <!-- Radial glow -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] bg-cyan-500/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute top-1/2 right-1/4 w-[400px] h-[400px] bg-blue-600/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm font-medium mb-8">
      <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
      Cloud-Native · DevSecOps · Kubernetes at Scale
    </div>

    <h1 class="text-5xl md:text-7xl font-extrabold text-white leading-tight tracking-tight mb-6">
      Engineering the
      <span class="block bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
        Cloud-Native Future
      </span>
    </h1>

    <p class="max-w-2xl mx-auto text-lg md:text-xl text-slate-400 leading-relaxed mb-10">
      We help organisations modernize, migrate, and secure their infrastructure on AWS, Azure, and GCP —
      with deep expertise in Kubernetes, scalable architectures, and DevSecOps.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#capabilities"
        class="px-8 py-3.5 rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-semibold hover:opacity-90 transition-opacity shadow-lg shadow-cyan-500/20"
      >
        Our Capabilities
      </a>
      <a
        href="#contact"
        class="px-8 py-3.5 rounded-xl border border-white/10 text-slate-300 font-semibold hover:border-white/30 hover:text-white transition-all duration-200"
      >
        Start a conversation
      </a>
    </div>

    <!-- Floating terminal snippet -->
    <div class="mt-20 max-w-2xl mx-auto text-left bg-[#0d1526] border border-white/10 rounded-2xl overflow-hidden shadow-2xl shadow-black/40">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5 bg-white/[0.02]">
        <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500/60"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/60"></span>
        <span class="ml-3 text-xs text-slate-500 font-['JetBrains_Mono',monospace]">cyberules ~ deploy</span>
      </div>
      <div class="px-5 py-4 font-['JetBrains_Mono',monospace] text-sm leading-7">
        <p><span class="text-slate-500">$</span> <span class="text-cyan-400">kubectl</span> <span class="text-slate-300">get nodes --all-namespaces</span></p>
        <p class="text-green-400">✔ 128 nodes ready across 3 regions</p>
        <p class="mt-1"><span class="text-slate-500">$</span> <span class="text-cyan-400">terraform</span> <span class="text-slate-300">apply -auto-approve</span></p>
        <p class="text-green-400">✔ 47 resources applied. Infrastructure secured.</p>
        <p class="mt-1"><span class="text-slate-500">$</span> <span class="text-cyan-400">trivy</span> <span class="text-slate-300">image --exit-code 0 app:latest</span></p>
        <p class="text-green-400">✔ 0 critical vulnerabilities detected</p>
        <p class="mt-1 text-slate-500">█<span class="animate-pulse">_</span></p>
      </div>
    </div>
  </div>
</section>
