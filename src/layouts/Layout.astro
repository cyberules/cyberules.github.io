---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Cyberules — Cloud-Native DevOps & DevSecOps',
  description = 'Expert cloud-native DevOps, Kubernetes at scale, and DevSecOps engineering. Modernizing and securing infrastructure on AWS, Azure, and GCP.',
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#060d1f] text-slate-300 font-['Inter',sans-serif] antialiased">
    <slot />
  </body>
</html>
