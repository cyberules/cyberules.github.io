---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Cyberules Consultancy — Cloud-Native DevOps & DevSecOps',
  description = 'Expert cloud-native DevOps, Kubernetes at scale, and DevSecOps engineering. Modernizing and securing infrastructure on AWS, Azure, and GCP.',
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#060d1f] text-slate-300 font-['Inter',sans-serif] antialiased">
    <slot />
  </body>
  <script>
    import translations from '../i18n/translations';
    import type { Lang } from '../i18n/translations';

    function applyLang(lang: Lang) {
      const t = translations[lang];
      document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')!;
        if (t[key] !== undefined) el.textContent = t[key];
      });
      document.querySelectorAll<HTMLElement>('[data-i18n-placeholder]').forEach(el => {
        const key = el.getAttribute('data-i18n-placeholder')!;
        if (t[key] !== undefined) (el as HTMLInputElement).placeholder = t[key];
      });
      document.querySelectorAll<HTMLButtonElement>('[data-lang-btn]').forEach(btn => {
        btn.classList.toggle('lang-active', btn.dataset.langBtn === lang);
      });
      document.documentElement.lang = lang === 'pt' ? 'pt-PT' : 'en';
      localStorage.setItem('cyberules-lang', lang);
    }

    document.querySelectorAll<HTMLButtonElement>('[data-lang-btn]').forEach(btn => {
      btn.addEventListener('click', () => applyLang(btn.dataset.langBtn as Lang));
    });

    const saved = (localStorage.getItem('cyberules-lang') as Lang) || 'en';
    applyLang(saved);
  </script>
</html>
